# Python
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Local environments
.venv/
venv/
.env
.env.*

# R
.Rhistory
.RData
.Ruserdata
renv/library/

# OS/editor
.DS_Store
Thumbs.db
*~
.git-local/

# Large/raw source archives. Keep folder documentation versioned.
# AFIP ZIP archives are intentionally versioned for GitHub backup.
data/input-data/**/*.rar
data/input-data/**/*.7z
data/input-data/**/*.gz

# Regenerable intermediates and outputs.
data/intermediate-data/*
!data/intermediate-data/.gitkeep
!data/intermediate-data/README.md
data/output-data/*
!data/output-data/.gitkeep
!data/output-data/README.md

# Regenerable analysis CSVs. The current final CSVs exceed GitHub's normal
# 100 MB file limit and are rebuilt by the reproducible pipeline.
data/analysis-data/*.csv

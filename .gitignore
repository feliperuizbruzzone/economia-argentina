# Large/raw source archives. Keep folder documentation versioned.
# AFIP ZIP archives are intentionally versioned for GitHub backup.
data/input-data/**/*.rar
data/input-data/**/*.7z
data/input-data/**/*.gz

# Regenerable intermediates and outputs.
data/intermediate-data/*
!data/intermediate-data/.gitkeep
!data/intermediate-data/README.md
data/output-data/*
!data/output-data/.gitkeep
!data/output-data/README.md

# Regenerable compressed legacy analysis CSVs.
data/analysis-data/*.csv.gz

# Regenerable analysis CSVs. The shareable final panel below is intentionally
# versionable because it is validated below GitHub's regular blob limit.
data/analysis-data/*.csv
!data/analysis-data/2026-07-10_afip_ganancias_sociedades_tidy_homologado.csv
